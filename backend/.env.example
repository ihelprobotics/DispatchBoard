## Backend example environment
## Copy to `backend/.env` and fill values.

# Server
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# Database (Supabase Postgres works fine here)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-1.5
GEMINI_TIMEOUT_MS=15000
# If you see "model not found" 404s, try forcing the API version order:
# GEMINI_API_VERSIONS=v1,v1beta
# Optional: comma-separated extra fallback models to try after GEMINI_MODEL:
# GEMINI_FALLBACK_MODELS=gemini-1.5-flash-latest

# Twilio WhatsApp webhook
# - Set your Twilio webhook to: https://YOUR_PUBLIC_URL/api/twilio-webhook
# - PUBLIC_URL must be the base URL only (no path), used for optional signature validation.
PUBLIC_URL=https://YOUR_DOMAIN_OR_NGROK_URL
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WhatsApp sender configured in Twilio (must be whatsapp:+...)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_DEBUG=false
DEBUG_ENDPOINTS=false

# Optional OCR for scanned PDFs (requires local Python+easyocr or Tesseract installed)
OCR_ENABLED=false
OCR_MODE=auto
# OCR_ENGINE:
# - auto: try EasyOCR (python) then Tesseract
# - easyocr: force EasyOCR (python package `easyocr` must be installed)
# - tesseract: force local Tesseract binary
# OCR_ENGINE=auto
# OCR_MODE:
# - auto: only OCR when PDF text extraction is too short
# - compare: run both PDF text + OCR and pick the one that looks more "order-like"
# - combine: include both texts (can be noisy / duplicate quantities)
# OCR_MODE=compare
# TESSERACT_CMD=tesseract
# PYTHON_CMD=python

# IMAP (disabled for now)
IMAP_ENABLED=false
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_SECURE=true
# IMAP_USER=you@gmail.com
# IMAP_PASS=your_app_password
